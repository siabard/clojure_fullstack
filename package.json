{
    "name": "clojure_fullstack",
    "version": "1.0.0",
    "scripts": {
	"dev:dev": "dotenv -e .env.development -- shadow-cljs watch app",
	"dev:prod": "dotenv -e .env.production -- shadow-cljs watch app",
	"build:dev": "dotenv -e .env.development -- shadow-cljs release app",
	"build:prod": "dotenv -e .env.production -- shadow-cljs release app"
    },
    "devDependencies": {
	"dotenv-cli": "^11.0.0",
	"shadow-cljs": "^2.18.4"
    },
    "dependencies": {
	"react": "^19.2.4",
	"react-dom": "^19.2.4"
    }
}
